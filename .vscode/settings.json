{
    "markdown.validate.enabled": true,
    "git.autofetch": false,
    "npm.autoDetect": "off",
    "typescript.disableAutomaticTypeAcquisition": true,
    "typescript.tsserver.maxTsServerMemory": 4096,
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/node_modules/**": true,
        "**/.next/**": true,
        "**/out/**": true,
        "**/build/**": true,
        "**/dist/**": true,
        "**/coverage/**": true,
        "**/.turbo/**": true,
        "**/.vercel/**": true,
        "**/.cache/**": true
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/.next": true,
        "**/out": true,
        "**/build": true,
        "**/dist": true,
        "**/coverage": true,
        "**/.turbo": true,
        "**/.vercel": true
    }
}