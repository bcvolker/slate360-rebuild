# =============================================================================
# Slate360 — Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# Production secrets live in Vercel environment variables.
# =============================================================================

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://hadnfcenpcfaeclczsmm.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Stripe ────────────────────────────────────────────────────────────────────
# Use TEST keys (sk_test_...) for local dev. NEVER use live keys locally.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Get webhook secret by running: stripe listen --forward-to localhost:3000/api/stripe/webhook

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-2
AWS_S3_BUCKET=slate360-storage

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Polymarket (Market Robot — only needed if working on Market tab) ──────────
# NEXT_PUBLIC_POLYMARKET_SPENDER=your_spender_address_here
# POLYMARKET_PRIVATE_KEY=your_private_key_here
