{
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install --ignore-scripts",
  "devCommand": "next dev",
  "crons": [
    {
      "path": "/api/ops/cron/recover-stale-twin-jobs",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/ops/cron/r2-cleanup",
      "schedule": "0 * * * *"
