# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
.tsbuildinfo-scoped
tsconfig.typecheck-scoped.json
next-env.d.ts
.gitnexus

# temporary debug/log files
ts.log
ts-errors.txt
*.log
.env*.local
supabase/.temp/

# v0.dev staging drop zone — never committed
/v0-staging/
public/sw.js
public/sw.js.map

# Brand audit screenshots (generated)
/.brand-audit/

# Local measurement/debug artifacts
/tmp-*
/tmp-*.json
/tmp-*.png
/.vercel-inspect.json
__pycache__/

# Local thermal camera sample files (private inspection data)
thermal-samples/

# Local intake drop zone — private analysis files (programs, installers, samples)
/local-intake/*
!/local-intake/README.md
!/local-intake/**/.gitkeep

# FLIR reference installers are local-only (too large for git)
/reference/flir-drive-import/installers/
