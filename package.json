{
  "name": "slate360-rebuild",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "typecheck": "tsc --noEmit",
    "guard:file-size-regression": "node scripts/ops/check-file-size-regression.mjs",
    "guard:architecture": "node scripts/ops/check-architecture-guardrails.mjs",
    "guard:build-stability": "node scripts/ops/check-build-stability.mjs",
    "guard:clob-contract": "node scripts/ops/check-clob-contract.mjs",
    "diag:market-runtime": "node scripts/ops/check-market-runtime.mjs",
    "verify:release": "node scripts/ops/verify-release.mjs",
    "start": "next start",
    "lint": "eslint",
    "smoke:auth-guards": "node scripts/ops/smoke-auth-guards.mjs",
    "market:burst:test": "node scripts/market-burst-test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:mobile": "node scripts/mobile-smoke-http.mjs",
    "test:e2e:mobile:playwright": "playwright test e2e/mobile-smoke.spec.ts",
    "test:e2e:headed": "playwright test --headed",
    "test:smoke:mobile": "node scripts/mobile-smoke-http.mjs",
    "test:diag:account": "node scripts/account-path-diagnostic.mjs",
    "mcp:setup": "npx gitnexus analyze && npx gitnexus setup",
    "mcp:start": "npx gitnexus mcp",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.995.0",
    "@aws-sdk/lib-storage": "^3.995.0",
    "@aws-sdk/s3-request-presigner": "^3.995.0",
    "@base-org/account": "^2.5.2",
    "@coinbase/wallet-sdk": "^4.3.7",
    "@metamask/sdk": "^0.33.1",
    "@polymarket/clob-client": "^5.2.4",
    "@safe-global/safe-apps-provider": "^0.18.6",
    "@safe-global/safe-apps-sdk": "^9.1.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "@tanstack/react-query": "^5.90.21",
    "@vis.gl/react-google-maps": "^1.7.1",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.575.0",
    "next": "^15.0.5",
    "nodemailer": "^8.0.1",
    "nuqs": "^2.8.9",
    "pdfjs-dist": "^5.4.624",
    "radix-ui": "^1.4.3",
    "react": "^19.0.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.0.1",
    "react-grid-layout": "^2.2.2",
    "react-pdf": "^10.4.0",
    "react-speech-recognition": "^4.0.1",
    "recharts": "^3.7.0",
    "regenerator-runtime": "^0.14.1",
    "resend": "^6.9.2",
    "stripe": "^20.3.1",
    "tailwind-merge": "^3.5.0",
    "viem": "^2.46.3",
    "wagmi": "^3.5.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@continuedev/cli": "^1.5.45",
    "@playwright/test": "^1.54.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.33",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-grid-layout": "^1.3.6",
    "@types/react-speech-recognition": "^3.9.6",
    "eslint": "^9",
    "eslint-config-next": "^15.0.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0 --no-warn-ignored --fix"
    ],
    "*.css": [
      "node -e \"const s=require('fs').readFileSync(process.argv[1],'utf8');const opens=(s.match(/\\{/g)||[]).length;const closes=(s.match(/\\}/g)||[]).length;if(opens!==closes){process.stderr.write('CSS brace mismatch: '+opens+' opens, '+closes+' closes\\n');process.exit(1);}console.log('CSS braces OK');\" $0"
    ]
  }
}
