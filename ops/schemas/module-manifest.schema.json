{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "module-manifest.schema.json",
  "type": "object",
  "required": ["updatedAt", "modules"],
  "properties": {
    "updatedAt": { "type": "string" },
    "owner": { "type": "string" },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "route", "gate", "canonicalSpec", "status"],
        "properties": {
          "id": { "type": "string" },
          "route": { "type": "string" },
          "gate": { "type": "string" },
          "canonicalSpec": { "type": "string" },
          "status": { "type": "string" },
          "primaryComponents": {
            "type": "array",
            "items": { "type": "string" }
          },
          "apis": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
