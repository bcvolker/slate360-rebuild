{
  "$schema": "./schemas/release-gates.schema.json",
  "updatedAt": "2026-03-05",
  "checks": [
    {
      "id": "architecture-guardrails",
      "required": true,
      "command": "npm run guard:architecture"
    },
    {
      "id": "file-size-regression",
      "required": true,
      "command": "npm run guard:file-size-regression"
    },
    {
      "id": "typecheck",
      "required": true,
      "command": "npx tsc --noEmit"
    },
    {
      "id": "build",
      "required": true,
      "command": "node scripts/ops/check-build-stability.mjs"
    },
    {
      "id": "lint",
      "required": false,
      "command": "eslint ."
    },
    {
      "id": "mobile-smoke",
      "required": false,
      "command": "node scripts/mobile-smoke-http.mjs"
    }
  ],
  "bugGate": {
    "requiredStatuses": ["fixed", "resolved", "mitigated"],
    "blockedSeverities": ["critical"]
  }
}
