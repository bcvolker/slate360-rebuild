{
  "$schema": "./schemas/release-gates.schema.json",
  "updatedAt": "2026-03-04",
  "checks": [
    {
      "id": "typecheck",
      "required": true,
      "command": "npx tsc --noEmit"
    },
    {
      "id": "build",
      "required": true,
      "command": "next build --no-lint"
    },
    {
      "id": "lint",
      "required": false,
      "command": "eslint ."
    },
    {
      "id": "mobile-smoke",
      "required": false,
      "command": "node scripts/mobile-smoke-http.mjs"
    }
  ],
  "bugGate": {
    "requiredStatuses": ["fixed", "resolved", "mitigated"],
    "blockedSeverities": ["critical"]
  }
}
